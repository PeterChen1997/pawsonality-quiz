            "value": 2,
            "effects": { "S1": 2, "E2": 2, "So3": 2, "Ac1": 2 }
          },
          {
            "label": "整只狗会突然精神起来，像听懂了“镜头已就位”。",
            "value": 3,
            "effects": { "S1": 3, "E2": 3, "So3": 3, "Ac1": 3 }
          }
        ]
      },
